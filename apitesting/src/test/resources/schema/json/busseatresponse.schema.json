{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["busId", "operator", "layout", "decks"],
  "properties": {
    "busId": {
      "type": "string"
    },
    "operator": {
      "type": "string"
    },
    "layout": {
      "type": "string",
      "const": "deck"
    },
    "decks": {
      "type": "object",
      "required": ["lower", "upper"],
      "properties": {
        "lower": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["seatId", "deck", "kind", "state"],
            "properties": {
              "seatId": {"type": "string"},
              "deck": {"type": "string", "const": "lower"},
              "kind": {"type": "string"},
              "state": {"type": "string"}
            },
            "additionalProperties": true
          }
        },
        "upper": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["seatId", "deck", "kind", "state"],
            "properties": {
              "seatId": {"type": "string"},
              "deck": {"type": "string", "const": "upper"},
              "kind": {"type": "string"},
              "state": {"type": "string"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}